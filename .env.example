APP_NAME=A2 Voice Processing Service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DB_URL=sqlite+aiosqlite:///./a2_voice.db
A2_ICAO_CODE=VHHH
A2_AUDIO_STORAGE=./data/audio
A2_CHUNK_SIZE=65536
A2_DISK_LIMIT_BYTES=10737418240
A2_DISK_SAFE_FREE_BYTES=2147483648
A2_LIVEATC_SEARCH_URL=https://www.liveatc.net/search/?icao={icao}
A2_LIVEATC_BASE_URL=https://www.liveatc.net
A2_LIVEATC_ARCHIVE_BASE_URL=https://archive.liveatc.net
A2_LIVEATC_MOUNT_IDS=vhhh5
A2_LIVEATC_REALTIME_STREAM_URL=
A2_REALTIME_CAPTURE_SECONDS=60
A2_REALTIME_CAPTURE_MAX_BYTES=2097152
A2_REALTIME_INTERVAL_SECONDS=90
A2_HISTORICAL_INTERVAL_SECONDS=900
A2_HISTORICAL_MAX_FILES_PER_RUN=5
A2_AUTO_START_SCHEDULER=true
A2_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
A2_HTTP_ACCEPT_LANGUAGE=en-US,en;q=0.9,zh-CN;q=0.8
A2_HTTP_MAX_RETRIES=2
A2_HTTP_COOKIE=
A3_CALLBACK_TOKEN=replace-with-secure-token
A3_SERVICE_BASE_URL=http://localhost:9000
